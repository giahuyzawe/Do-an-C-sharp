<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FoodStreetGuide.SettingsPage"
    Title="Cài đặt"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0,16,0,16">

            <!-- Profile Header -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,8,0,24">
                <!-- Avatar -->
                <Frame WidthRequest="80"
                       HeightRequest="80"
                       CornerRadius="40"
                       Padding="0"
                       BackgroundColor="{StaticResource Primary}"
                       BorderColor="Transparent"
                       HorizontalOptions="Center"
                       IsClippedToBounds="True">
                    <Label Text="👤"
                           FontSize="36"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>
                <Label x:Name="profileNameLabel"
                       Text="Người dùng FoodStreetGuide"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center"/>
                <Label x:Name="profileSubtitleLabel"
                       Text="Khám phá nhà hàng gần bạn"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- GEOFENCE Section -->
            <Label x:Name="geofenceSectionLabel" Text="PHẠM VI PHÁT HIỆN"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="16,8,16,6"/>

            <Frame Margin="16,4" Padding="0"
                   BackgroundColor="{StaticResource Surface}"
                   CornerRadius="12"
                   HasShadow="True">
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label x:Name="radiusLabel" Text="Bán kính phát hiện" FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                            <Label x:Name="radiusValueLabel" Text="100m" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Slider x:Name="radiusSlider" Grid.Column="1"
                                WidthRequest="140"
                                Minimum="50" Maximum="500" Value="100"
                                ValueChanged="OnRadiusChanged"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" Margin="16,0"/>
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label x:Name="cooldownLabel" Text="Thời gian chờ" FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                            <Label x:Name="cooldownValueLabel" Text="5 phút" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Slider x:Name="cooldownSlider" Grid.Column="1"
                                WidthRequest="140"
                                Minimum="1" Maximum="30" Value="5"
                                ValueChanged="OnCooldownChanged"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- NARRATION Section -->
            <Label x:Name="narrationSectionLabel" Text="THUYẾT MINH"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="16,20,16,6"/>

            <Frame Margin="16,4" Padding="0"
                   BackgroundColor="{StaticResource Surface}"
                   CornerRadius="12"
                   HasShadow="True">
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               x:Name="enableNarrationLabel" Text="Bật thuyết minh"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center"/>
                        <Switch x:Name="narrationSwitch" Grid.Column="1"
                                Toggled="OnNarrationToggled"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" Margin="16,0"/>
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               x:Name="languageLabel" Text="Ngôn ngữ"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center"/>
                        <Picker x:Name="voicePicker" Grid.Column="1"
                                WidthRequest="120"
                                SelectedIndexChanged="OnVoiceChanged">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Tiếng Việt</x:String>
                                    <x:String>English</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" Margin="16,0"/>
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label x:Name="speedLabel" Text="Tốc độ nói" FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                            <Label x:Name="speedValueLabel" Text="1.0x" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Slider x:Name="speedSlider" Grid.Column="1"
                                WidthRequest="140"
                                Minimum="0.5" Maximum="2.0" Value="1.0"
                                ValueChanged="OnSpeedChanged"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- GPS Section -->
            <Label x:Name="gpsSectionLabel" Text="GPS"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="16,20,16,6"/>

            <Frame Margin="16,4" Padding="0"
                   BackgroundColor="{StaticResource Surface}"
                   CornerRadius="12"
                   HasShadow="True">
                <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="intervalLabel" Text="Khoảng thời gian cập nhật" FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                        <Label x:Name="intervalValueLabel" Text="3 giây" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                    <Slider x:Name="intervalSlider" Grid.Column="1"
                            WidthRequest="140"
                            Minimum="1" Maximum="10" Value="3"
                            ValueChanged="OnIntervalChanged"/>
                </Grid>
            </Frame>

            <!-- About Section -->
            <Label x:Name="aboutSectionLabel" Text="GIỚI THIỆU"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="16,24,16,6"/>

            <Frame Margin="16,4" Padding="0"
                   BackgroundColor="{StaticResource Surface}"
                   CornerRadius="12"
                   HasShadow="True">
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                        <Label x:Name="versionLabel" Grid.Column="0" Text="Phiên bản" FontSize="14" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="1.0.0" FontSize="14" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" Margin="16,0"/>
                    <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                        <Label x:Name="developerLabel" Grid.Column="0" Text="Nhà phát triển" FontSize="14" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="FoodStreetGuide Team" FontSize="14" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Footer -->
            <Label Text="FoodStreetGuide v1.0"
                   FontSize="12"
                   TextColor="{StaticResource TextTertiary}"
                   HorizontalOptions="Center"
                   Margin="0,20,0,8"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
