<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FoodStreetGuide.SettingsPage"
    Title="Profile"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0,16,0,16">

            <!-- Profile Header -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,8,0,24">
                <!-- Avatar -->
                <Frame WidthRequest="80"
                       HeightRequest="80"
                       CornerRadius="40"
                       Padding="0"
                       BackgroundColor="{StaticResource Primary}"
                       BorderColor="Transparent"
                       HorizontalOptions="Center"
                       IsClippedToBounds="True">
                    <Label Text="👤"
                           FontSize="36"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>
                <Label Text="FoodStreetGuide User"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center"/>
                <Label Text="Explore nearby restaurants"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- GEOFENCE Section -->
            <Label Text="GEOFENCE"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="16,8,16,6"/>

            <Frame Margin="16,4" Padding="0"
                   BackgroundColor="{StaticResource Surface}"
                   CornerRadius="12"
                   HasShadow="True">
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Detection radius" FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                            <Label x:Name="radiusValueLabel" Text="100m" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Slider x:Name="radiusSlider" Grid.Column="1"
                                WidthRequest="140"
                                Minimum="50" Maximum="500" Value="100"
                                ValueChanged="OnRadiusChanged"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" Margin="16,0"/>
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Cooldown" FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                            <Label x:Name="cooldownValueLabel" Text="5 min" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Slider x:Name="cooldownSlider" Grid.Column="1"
                                WidthRequest="140"
                                Minimum="1" Maximum="30" Value="5"
                                ValueChanged="OnCooldownChanged"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- NARRATION Section -->
            <Label Text="NARRATION"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="16,20,16,6"/>

            <Frame Margin="16,4" Padding="0"
                   BackgroundColor="{StaticResource Surface}"
                   CornerRadius="12"
                   HasShadow="True">
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Enable narration"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center"/>
                        <Switch x:Name="narrationSwitch" Grid.Column="1"
                                Toggled="OnNarrationToggled"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" Margin="16,0"/>
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Language"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center"/>
                        <Picker x:Name="voicePicker" Grid.Column="1"
                                WidthRequest="120"
                                SelectedIndexChanged="OnVoiceChanged">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Tieng Viet</x:String>
                                    <x:String>English</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" Margin="16,0"/>
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Speech speed" FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                            <Label x:Name="speedValueLabel" Text="1.0x" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Slider x:Name="speedSlider" Grid.Column="1"
                                WidthRequest="140"
                                Minimum="0.5" Maximum="2.0" Value="1.0"
                                ValueChanged="OnSpeedChanged"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- GPS Section -->
            <Label Text="GPS"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="16,20,16,6"/>

            <Frame Margin="16,4" Padding="0"
                   BackgroundColor="{StaticResource Surface}"
                   CornerRadius="12"
                   HasShadow="True">
                <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Update interval" FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                        <Label x:Name="intervalValueLabel" Text="3 sec" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                    <Slider x:Name="intervalSlider" Grid.Column="1"
                            WidthRequest="140"
                            Minimum="1" Maximum="10" Value="3"
                            ValueChanged="OnIntervalChanged"/>
                </Grid>
            </Frame>

            <!-- Sync Button -->
            <Button Text="Sync Data"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource TextWhite}"
                    CornerRadius="12"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    Margin="16,24,16,0"
                    Clicked="OnSyncButtonClicked"/>

            <!-- About Section -->
            <Label Text="ABOUT"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="16,24,16,6"/>

            <Frame Margin="16,4" Padding="0"
                   BackgroundColor="{StaticResource Surface}"
                   CornerRadius="12"
                   HasShadow="True">
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="App version" FontSize="14" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="1.0.0" FontSize="14" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" Margin="16,0"/>
                    <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Developer" FontSize="14" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="FoodStreetGuide Team" FontSize="14" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Footer -->
            <Label Text="FoodStreetGuide v1.0"
                   FontSize="12"
                   TextColor="{StaticResource TextTertiary}"
                   HorizontalOptions="Center"
                   Margin="0,20,0,8"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
