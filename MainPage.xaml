<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="FoodStreetGuide.MainPage"
             Shell.TabBarIsVisible="True"
             BackgroundColor="#F7F7F7">

    <!-- MAIN LAYOUT: Map + Overlays -->
    <AbsoluteLayout VerticalOptions="Fill" HorizontalOptions="Fill">

        <!-- 1. FULL SCREEN MAP (without built-in UI controls) -->
        <maps:Map x:Name="map"
                  AbsoluteLayout.LayoutBounds="0,0,1,1"
                  AbsoluteLayout.LayoutFlags="All"
                  MapType="Street"
                  IsShowingUser="False"
                  IsZoomEnabled="False"
                  IsScrollEnabled="True"/>

        <!-- 2. SEARCH BAR (TOP) -->
        <Frame x:Name="searchBarFrame"
               AbsoluteLayout.LayoutBounds="0.5,16,1,56"
               AbsoluteLayout.LayoutFlags="XProportional,WidthProportional"
               Margin="16,0,16,0"
               Padding="0"
               BackgroundColor="White"
               CornerRadius="16"
               HasShadow="True"
               BorderColor="#E3E3E3">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="12,0">
                <!-- Search Icon -->
                <Label Grid.Column="0"
                       Text="&#128269;"
                       FontSize="18"
                       TextColor="#2D2D2D"
                       VerticalOptions="Center"/>
                <!-- Search Entry -->
                <Entry x:Name="searchEntry"
                       Grid.Column="1"
                       Placeholder="Tìm nhà hàng hoặc món ăn..."
                       PlaceholderColor="#999999"
                       TextColor="#2D2D2D"
                       FontSize="14"
                       VerticalOptions="Center"
                       Margin="8,0,0,0"
                       BackgroundColor="Transparent"
                       Completed="OnSearchCompleted"
                       TextChanged="OnSearchTextChanged"/>
                <!-- Clear Button -->
                <Label x:Name="clearSearchLabel"
                       Grid.Column="2"
                       Text="&#10005;"
                       FontSize="16"
                       TextColor="#999999"
                       VerticalOptions="Center"
                       IsVisible="False">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnClearSearchTapped"/>
                    </Label.GestureRecognizers>
                </Label>
                <!-- Filter Icon -->
                <Label Grid.Column="3"
                       Text="&#9881;"
                       FontSize="18"
                       TextColor="#2D2D2D"
                       VerticalOptions="Center"
                       Margin="8,0,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Frame>

        <!-- 3. TRACKING STATUS BADGE -->
        <Frame x:Name="trackingIndicator"
               AbsoluteLayout.LayoutBounds="0.5,72,-1,-1"
               AbsoluteLayout.LayoutFlags="XProportional"
               Padding="12,6"
               BackgroundColor="White"
               CornerRadius="16"
               HasShadow="True"
               IsVisible="False"
               BorderColor="#E3E3E3">
            <HorizontalStackLayout Spacing="6">
                <Ellipse WidthRequest="8" HeightRequest="8" Fill="#4CAF50"/>
                <Label x:Name="trackingStatusLabel"
                       Text="Đang theo dõi"
                       TextColor="#2D2D2D"
                       FontSize="12"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Frame>

        <!-- 3.5 RIGHT SIDE BUTTONS (Top area) -->
        <VerticalStackLayout AbsoluteLayout.LayoutBounds="1,80,-1,-1"
                             AbsoluteLayout.LayoutFlags="XProportional"
                             Margin="0,0,16,0"
                             Spacing="8">
            <!-- Recenter -->
            <Frame x:Name="locationButtonFrame"
                   Padding="0"
                   BackgroundColor="White"
                   CornerRadius="10"
                   WidthRequest="40"
                   HeightRequest="40"
                   HasShadow="True"
                   BorderColor="#E3E3E3">
                <Button x:Name="locationButton"
                        Text="&#128205;"
                        FontSize="20"
                        BackgroundColor="Transparent"
                        TextColor="#2D2D2D"
                        Padding="0"
                        Clicked="OnRecenterTapped"/>
            </Frame>
            <!-- Zoom In -->
            <Frame x:Name="zoomInButtonFrame"
                   Padding="0"
                   BackgroundColor="White"
                   CornerRadius="10"
                   WidthRequest="40"
                   HeightRequest="40"
                   HasShadow="True"
                   BorderColor="#E3E3E3">
                <Button x:Name="zoomInButton"
                        Text="&#43;"
                        FontSize="20"
                        BackgroundColor="Transparent"
                        TextColor="#2D2D2D"
                        Padding="0"
                        Clicked="OnZoomInClicked"/>
            </Frame>
            <!-- Zoom Out -->
            <Frame x:Name="zoomOutButtonFrame"
                   Padding="0"
                   BackgroundColor="White"
                   CornerRadius="10"
                   WidthRequest="40"
                   HeightRequest="40"
                   HasShadow="True"
                   BorderColor="#E3E3E3">
                <Button x:Name="zoomOutButton"
                        Text="&#8722;"
                        FontSize="20"
                        BackgroundColor="Transparent"
                        TextColor="#2D2D2D"
                        Padding="0"
                        Clicked="OnZoomOutClicked"/>
            </Frame>
        </VerticalStackLayout>

        <!-- 4. CONTROL BAR (BOTTOM) - White background wrapper -->
        <Frame x:Name="controlBarFrame"
               AbsoluteLayout.LayoutBounds="0.5,1,AutoSize,AutoSize"
               AbsoluteLayout.LayoutFlags="XProportional,YProportional"
               Margin="0,0,0,20"
               Padding="12,8"
               BackgroundColor="White"
               CornerRadius="20"
               HasShadow="True"
               BorderColor="#E3E3E3"
               ZIndex="5">
            <HorizontalStackLayout x:Name="controlBar"
                                 Spacing="12"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center">

            <!-- 5.1 TRACKING BUTTON -->
            <Frame x:Name="trackButtonFrame"
                   Padding="0"
                   BackgroundColor="#FF6B35"
                   CornerRadius="14"
                   WidthRequest="120"
                   HeightRequest="44"
                   HasShadow="True"
                   BorderColor="Transparent">
                <Button x:Name="trackButton"
                        Text="Tracking"
                        FontSize="14"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        Padding="0"
                        Clicked="OnTrackButtonClicked"/>
            </Frame>

            <!-- 5.2 NEAREST POI BUTTON -->
            <Frame x:Name="nearestButtonFrame"
                   Padding="0"
                   BackgroundColor="White"
                   CornerRadius="14"
                   WidthRequest="110"
                   HeightRequest="44"
                   HasShadow="True"
                   BorderColor="#E3E3E3">
                <Button x:Name="nearestButton"
                        Text="Nearest"
                        FontSize="14"
                        BackgroundColor="Transparent"
                        TextColor="#2D2D2D"
                        Padding="0"
                        Clicked="OnFindNearestClicked"/>
            </Frame>

            <!-- 5.3 QR SCAN BUTTON -->
            <Frame x:Name="qrButtonFrame"
                   Padding="0"
                   BackgroundColor="White"
                   CornerRadius="14"
                   WidthRequest="44"
                   HeightRequest="44"
                   HasShadow="True"
                   BorderColor="#E3E3E3">
                <Button x:Name="qrButton"
                        Text="QR"
                        FontSize="12"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        TextColor="#2D2D2D"
                        Padding="0"
                        Clicked="OnQRScanClicked"/>
            </Frame>

            </HorizontalStackLayout>
        </Frame>

        <!-- 6. POI CARD (BOTTOM SHEET) - Compact layout -->
        <Border x:Name="poiCard"
                AbsoluteLayout.LayoutBounds="0,1,1,AutoSize"
                AbsoluteLayout.LayoutFlags="XProportional,YProportional,WidthProportional"
                Margin="0,0,0,0"
                Padding="0,0,0,8"
                BackgroundColor="White"
                Stroke="White"
                StrokeThickness="0"
                IsVisible="False"
                ZIndex="200">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="0">

                <!-- Drag Handle -->
                <BoxView WidthRequest="40"
                         HeightRequest="4"
                         BackgroundColor="#CCCCCC"
                         CornerRadius="2"
                         HorizontalOptions="Center"
                         Margin="0,6,0,4"/>

                <!-- Restaurant Image Carousel -->
                <Grid Margin="16,0,16,4" HeightRequest="100">
                    <CarouselView x:Name="poiImageCarousel"
                                  Loop="False"
                                  IsSwipeEnabled="True"
                                  HeightRequest="100"
                                  IndicatorView="poiImageIndicator">
                        <CarouselView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="0"
                                       CornerRadius="12"
                                       IsClippedToBounds="True"
                                       BorderColor="Transparent"
                                       BackgroundColor="#F0F0F0">
                                    <Image Source="{Binding .}"
                                           Aspect="AspectFill"
                                           HeightRequest="100"/>
                                </Frame>
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>
                    <!-- Image Indicator -->
                    <IndicatorView x:Name="poiImageIndicator"
                                   IndicatorColor="#CCCCCC"
                                   SelectedIndicatorColor="#FF6B35"
                                   IndicatorSize="6"
                                   HorizontalOptions="Center"
                                   VerticalOptions="End"
                                   Margin="0,0,0,8"/>
                </Grid>

                <!-- Restaurant Name -->
                <Label x:Name="poiNameLabel"
                       Text="Tên nhà hàng"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#2D2D2D"
                       LineBreakMode="TailTruncation"
                       Margin="16,2,16,2"/>

                <!-- Rating • Distance • Status -->
                <HorizontalStackLayout Margin="16,0,16,2" Spacing="8">
                    <Label x:Name="poiRatingLabel"
                           Text="&#11088; 4.5"
                           FontSize="13"
                           TextColor="#666666"/>
                    <Label Text="&#8226;" FontSize="13" TextColor="#999999" VerticalOptions="Center"/>
                    <Label x:Name="poiDistanceLabel"
                           Text="120m away"
                           FontSize="13"
                           TextColor="#666666"/>
                    <Label Text="&#8226;" FontSize="13" TextColor="#999999" VerticalOptions="Center"/>
                    <Label x:Name="poiStatusLabel"
                           Text="Đang mở cửa"
                           FontSize="13"
                           TextColor="#4CAF50"/>
                </HorizontalStackLayout>

                <!-- Address -->
                <Label x:Name="poiAddressLabel"
                       Text="Địa chỉ nhà hàng"
                       FontSize="12"
                       TextColor="#999999"
                       LineBreakMode="TailTruncation"
                       Margin="16,0,16,8"/>

                <!-- Action Buttons -->
                <FlexLayout Direction="Row"
                            JustifyContent="SpaceEvenly"
                            AlignItems="Center"
                            Padding="8,0,8,8"
                            HeightRequest="44">

                    <!-- Nghe -->
                    <Frame x:Name="listenButtonFrame"
                           Padding="8,0"
                           CornerRadius="20"
                           HeightRequest="40"
                           WidthRequest="90"
                           BackgroundColor="#FF6B35"
                           BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNarrateClicked"/>
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                            <Label Text="&#9658;" FontSize="12" VerticalOptions="Center" TextColor="White"/>
                            <Label x:Name="listenLabel" Text="Listen" FontSize="12" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Frame>

                    <!-- Chi duong -->
                    <Frame x:Name="directionsButtonFrame"
                           Padding="8,0"
                           CornerRadius="20"
                           HeightRequest="40"
                           WidthRequest="90"
                           BackgroundColor="#F7F7F7"
                           BorderColor="#E3E3E3">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDirectionsClicked"/>
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                            <Label Text="&#10148;" FontSize="14" VerticalOptions="Center" TextColor="#2D2D2D"/>
                            <Label x:Name="directionsLabel" Text="Directions" FontSize="12" TextColor="#2D2D2D" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Frame>

                    <!-- Chi tiet -->
                    <Frame x:Name="detailsButtonFrame"
                           Padding="8,0"
                           CornerRadius="20"
                           HeightRequest="40"
                           WidthRequest="90"
                           BackgroundColor="#F7F7F7"
                           BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDetailsClicked"/>
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                            <Label Text="&#8505;" FontSize="14" VerticalOptions="Center" TextColor="#2D2D2D"/>
                            <Label x:Name="detailsLabel" Text="Details" FontSize="12" TextColor="#2D2D2D" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Frame>

                    <!-- Luu - Toggle save state -->
                    <Frame x:Name="saveButtonFrame"
                           Padding="0"
                           CornerRadius="20"
                           HeightRequest="40"
                           WidthRequest="40"
                           BackgroundColor="#F7F7F7"
                           BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSaveClicked"/>
                        </Frame.GestureRecognizers>
                        <Label x:Name="saveHeartLabel"
                               Text="&#10084;" 
                               FontSize="16" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" 
                               TextColor="#666666"/>
                    </Frame>
                </FlexLayout>

            </VerticalStackLayout>

            <!-- Swipe to close gesture -->
            <Border.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Down" Swiped="OnClosePOICardSwiped"/>
            </Border.GestureRecognizers>
        </Border>

        <!-- SEARCH RESULTS LIST - Shows when multiple results found -->
        <ScrollView x:Name="searchResultsScroll"
                    AbsoluteLayout.LayoutBounds="0,1,1,AutoSize"
                    AbsoluteLayout.LayoutFlags="XProportional,YProportional,WidthProportional"
                    Margin="0,0,0,0"
                    Padding="8,8,8,8"
                    BackgroundColor="#FFFFFF"
                    IsVisible="False"
                    ZIndex="150">
            <HorizontalStackLayout x:Name="searchResultsList"
                                    Spacing="8"
                                    Padding="8,4">
                <!-- Search result chips will be added dynamically -->
            </HorizontalStackLayout>
        </ScrollView>

    </AbsoluteLayout>

</ContentPage>
