@page
@model FoodStreetGuide.Admin.Pages.Restaurants.IndexModel
@{
    ViewData["Title"] = "Restaurants";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Restaurants</h1>
        <p class="text-muted mb-0">Manage restaurants and menus</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="./Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Add Restaurant
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Address</th>
                        <th>Rating</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Restaurants)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Images))
                                {
                                    <img src="@item.Images.Split(',')[0]" class="rounded" style="width: 50px; height: 50px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-secondary bg-opacity-10 rounded d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="bi bi-shop text-secondary"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-medium">@item.Name</div>
                                <small class="text-muted">@item.PriceRange • @item.OpenHours</small>
                            </td>
                            <td><span class="badge bg-light text-dark">@item.Category</span></td>
                            <td><small class="text-muted">@item.Address</small></td>
                            <td>
                                <span class="badge bg-warning">@item.Rating.ToString("F1")</span>
                                <small class="text-muted">(@item.RatingCount)</small>
                            </td>
                            <td>
                                <span class="badge @(item.Status == "active" ? "bg-success" : "bg-secondary")">@item.Status</span>
                                @if (item.IsHighlighted)
                                {
                                    <span class="badge bg-info ms-1"><i class="bi bi-star-fill"></i></span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-page="./Edit" asp-route-id="@item.Id"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                                        <li><a class="dropdown-item" asp-page="./Menu" asp-route-id="@item.Id"><i class="bi bi-list me-2"></i>Menu</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item @(item.IsHighlighted ? "text-warning" : "")" asp-page-handler="ToggleHighlight" asp-route-id="@item.Id"><i class="bi bi-star me-2"></i>@(item.IsHighlighted ? "Remove" : "Add") Highlight</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
