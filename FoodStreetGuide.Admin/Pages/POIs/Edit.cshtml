@page "{id:int?}"
@model FoodStreetGuide.Admin.Pages.POIs.EditModel
@{
    ViewData["Title"] = Model.POI.Id == 0 ? "Add POI" : "Edit POI";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">@(Model.POI.Id == 0 ? "Create new Point of Interest" : "Edit POI details")</p>
    </div>
    <a asp-page="./Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back
    </a>
</div>

<form method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="POI.Id" />
    <input type="hidden" asp-for="POI.CreatedAt" />

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Basic Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="POI.NameVi" class="form-label">Name (Vietnamese) *</label>
                        <input asp-for="POI.NameVi" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="POI.NameEn" class="form-label">Name (English)</label>
                        <input asp-for="POI.NameEn" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="POI.DescriptionVi" class="form-label">Description (Vietnamese)</label>
                        <textarea asp-for="POI.DescriptionVi" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="POI.DescriptionEn" class="form-label">Description (English)</label>
                        <textarea asp-for="POI.DescriptionEn" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="POI.Category" class="form-label">Category</label>
                        <select asp-for="POI.Category" class="form-select" asp-items="Model.Categories"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="POI.Address" class="form-label">Address</label>
                        <input asp-for="POI.Address" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="POI.Tags" class="form-label">Tags (comma separated)</label>
                        <input asp-for="POI.Tags" class="form-control" placeholder="street food, historic, night market" />
                    </div>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Geofence Settings</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="POI.Radius" class="form-label">Trigger Radius</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="range" class="form-range" min="50" max="500" step="50" value="@Model.POI.Radius" oninput="document.getElementById('radiusValue').textContent = this.value + 'm'" />
                                <span id="radiusValue" class="badge bg-primary">@Model.POI.Radius m</span>
                            </div>
                            <input type="hidden" asp-for="POI.Radius" id="radiusInput" value="@Model.POI.Radius" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="POI.Priority" class="form-label">Priority Level</label>
                            <select asp-for="POI.Priority" class="form-select">
                                <option value="1">Low</option>
                                <option value="2">Medium</option>
                                <option value="3">High</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-mic me-2"></i>Narration</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="POI.NarrationType" class="form-label">Narration Type</label>
                        <select asp-for="POI.NarrationType" class="form-select">
                            <option value="tts">Text-to-Speech</option>
                            <option value="audio">Audio File</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Upload Audio</label>
                        <input type="file" name="AudioFile" class="form-control" accept="audio/*" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Upload Image</label>
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Map -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-map me-2"></i>Location on Map</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-6">
                            <label asp-for="POI.Latitude" class="form-label">Latitude</label>
                            <input asp-for="POI.Latitude" class="form-control" id="latitude" step="any" required />
                        </div>
                        <div class="col-6">
                            <label asp-for="POI.Longitude" class="form-label">Longitude</label>
                            <input asp-for="POI.Longitude" class="form-control" id="longitude" step="any" required />
                        </div>
                    </div>
                    <div id="map" style="height: 400px; border-radius: 8px;"></div>
                    <small class="text-muted">Click on map or drag marker to set location</small>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-sliders me-2"></i>Status</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="POI.Status" class="form-label">Status</label>
                        <select asp-for="POI.Status" class="form-select">
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                            <option value="draft">Draft</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-2"></i>Save
        </button>
        <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="button" class="btn btn-outline-info ms-auto" onclick="previewPOI()">
            <i class="bi bi-eye me-2"></i>Preview
        </button>
    </div>
</form>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const lat = parseFloat(document.getElementById('latitude').value) || 10.762622;
        const lng = parseFloat(document.getElementById('longitude').value) || 106.660172;

        const map = L.map('map').setView([lat, lng], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        let marker = L.marker([lat, lng], { draggable: true }).addTo(map);
        let circle = L.circle([lat, lng], { radius: @(Model.POI.Radius * 1.0), color: '#4F46E5', fillOpacity: 0.1 }).addTo(map);

        function updatePosition(pos) {
            document.getElementById('latitude').value = pos.lat.toFixed(6);
            document.getElementById('longitude').value = pos.lng.toFixed(6);
            circle.setLatLng(pos);
        }

        marker.on('dragend', e => updatePosition(e.target.getLatLng()));
        map.on('click', e => {
            marker.setLatLng(e.latlng);
            updatePosition(e.latlng);
        });

        document.querySelector('input[type="range"]').addEventListener('input', function() {
            document.getElementById('radiusInput').value = this.value;
            circle.setRadius(parseInt(this.value));
        });

        function previewPOI() {
            alert('Preview functionality - would show POI as it appears in mobile app');
        }
    </script>
}
