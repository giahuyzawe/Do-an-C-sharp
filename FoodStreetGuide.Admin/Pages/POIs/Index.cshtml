@page
@model FoodStreetGuide.Admin.Pages.POIs.IndexModel
@{
    ViewData["Title"] = "POI Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">POI Management</h1>
        <p class="text-muted mb-0">Manage Points of Interest</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="./Map" class="btn btn-outline-info">
            <i class="bi bi-map me-2"></i>Map View
        </a>
        <a asp-page="./Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Add POI
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" name="search" value="@Model.Search" placeholder="Search POI..." />
                </div>
            </div>
            <div class="col-md-2">
                <select class="form-select" name="category" asp-items="Model.CategoryOptions">
                    <option value="">All Categories</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" name="status" asp-items="Model.StatusOptions">
                    <option value="">All Status</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" name="sort" asp-items="Model.SortOptions"></select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<!-- Bulk Actions -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex gap-2">
        <select class="form-select form-select-sm w-auto" id="bulkAction">
            <option value="">Bulk Actions</option>
            <option value="delete">Delete Selected</option>
            <option value="disable">Disable Selected</option>
            <option value="enable">Enable Selected</option>
        </select>
        <button class="btn btn-sm btn-outline-secondary" onclick="applyBulkAction()">Apply</button>
    </div>
    <small class="text-muted">@Model.TotalItems total items</small>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th width="40"><input type="checkbox" class="form-check-input" id="selectAll" /></th>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Location</th>
                        <th>Radius</th>
                        <th>Priority</th>
                        <th>Audio</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.POIs)
                    {
                        <tr>
                            <td><input type="checkbox" class="form-check-input item-check" value="@item.Id" /></td>
                            <td><small class="text-muted">#@item.Id</small></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="rounded me-2" style="width: 40px; height: 40px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-primary bg-opacity-10 text-primary rounded d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                                            <i class="bi bi-geo-alt-fill"></i>
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-medium">@item.NameVi</div>
                                        <small class="text-muted">@(item.NameEn ?? "-")</small>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-light text-dark">@item.Category</span></td>
                            <td>
                                <small class="text-muted">@item.Latitude.ToString("F4"), @item.Longitude.ToString("F4")</small>
                            </td>
                            <td>@item.Radius m</td>
                            <td>
                                <span class="badge @(item.Priority >= 3 ? "bg-danger" : item.Priority == 2 ? "bg-warning" : "bg-success")">
                                    @(item.Priority == 1 ? "Low" : item.Priority == 2 ? "Medium" : "High")
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.AudioUrl))
                                {
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle-fill text-muted"></i>
                                }
                            </td>
                            <td>
                                <span class="badge @(item.Status == "active" ? "bg-success" : "bg-secondary")">
                                    @item.Status
                                </span>
                            </td>
                            <td><small>@item.CreatedAt.ToString("MMM dd, yyyy")</small></td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-page="./Details" asp-route-id="@item.Id"><i class="bi bi-eye me-2"></i>View</a></li>
                                        <li><a class="dropdown-item" asp-page="./Edit" asp-route-id="@item.Id"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                                        <li><a class="dropdown-item" asp-page="./MapPreview" asp-route-id="@item.Id"><i class="bi bi-map me-2"></i>Preview on Map</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" href="#" onclick="deletePOI(@item.Id)"><i class="bi bi-trash me-2"></i>Delete</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            <nav>
                <ul class="pagination justify-content-center mb-0">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-category="@Model.Category" asp-route-status="@Model.Status">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

<form id="deleteForm" method="post" asp-page-handler="Delete">
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script>
        document.getElementById('selectAll').addEventListener('change', function() {
            document.querySelectorAll('.item-check').forEach(cb => cb.checked = this.checked);
        });

        function deletePOI(id) {
            if (confirm('Are you sure you want to delete this POI?')) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }

        function applyBulkAction() {
            const action = document.getElementById('bulkAction').value;
            const selected = Array.from(document.querySelectorAll('.item-check:checked')).map(cb => cb.value);
            if (!action || selected.length === 0) return;
            if (confirm(`Are you sure you want to ${action} ${selected.length} items?`)) {
                // Submit bulk action
            }
        }
    </script>
}
