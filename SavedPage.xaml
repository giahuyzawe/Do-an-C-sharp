<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodStreetGuide.SavedPage"
             Title="Đã lưu"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="16,16,16,8" Spacing="4">
            <Label x:Name="headerTitleLabel" Text="Đã lưu"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"/>
            <Label x:Name="headerSubtitleLabel" Text="Nhà hàng yêu thích của bạn"
                   FontSize="14"
                   TextColor="{StaticResource TextSecondary}"/>
        </VerticalStackLayout>

        <!-- Saved List -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,16" Spacing="12">

                <!-- Item 1 -->
                <Frame x:Name="savedItem1"
                       BackgroundColor="{StaticResource Surface}"
                       CornerRadius="16"
                       HasShadow="True"
                       Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSavedItemTapped" CommandParameter="0"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="12">
                        <Frame Grid.Column="0"
                               CornerRadius="12"
                               Padding="0"
                               IsClippedToBounds="True"
                               WidthRequest="72"
                               HeightRequest="72"
                               BackgroundColor="#FFE8D6"
                               BorderColor="Transparent">
                            <Label Text="🍜" FontSize="32"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label x:Name="savedName1" Text="Pho Hoa Pasteur"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <HorizontalStackLayout Spacing="2">
                                <Label Text="★★★★" FontSize="12" TextColor="{StaticResource StarFilled}"/>
                                <Label Text="★" FontSize="12" TextColor="{StaticResource StarEmpty}"/>
                                <Label x:Name="savedRating1" Text="4.8" FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" Margin="2,0,0,0"/>
                            </HorizontalStackLayout>
                            <Label x:Name="savedDistance1" Text="500m"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label x:Name="savedHeart1"
                               Grid.Column="2"
                               Text="❤️"
                               FontSize="20"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRemoveFavoriteTapped" CommandParameter="0"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Frame>

                <!-- Item 2 -->
                <Frame x:Name="savedItem2"
                       BackgroundColor="{StaticResource Surface}"
                       CornerRadius="16"
                       HasShadow="True"
                       Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSavedItemTapped" CommandParameter="1"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="12">
                        <Frame Grid.Column="0"
                               CornerRadius="12"
                               Padding="0"
                               IsClippedToBounds="True"
                               WidthRequest="72"
                               HeightRequest="72"
                               BackgroundColor="#FFF0D9"
                               BorderColor="Transparent">
                            <Label Text="🥖" FontSize="32"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label x:Name="savedName2" Text="Banh Mi Huynh Hoa"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <HorizontalStackLayout Spacing="2">
                                <Label Text="★★★★" FontSize="12" TextColor="{StaticResource StarFilled}"/>
                                <Label Text="★" FontSize="12" TextColor="{StaticResource StarEmpty}"/>
                                <Label x:Name="savedRating2" Text="4.6" FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" Margin="2,0,0,0"/>
                            </HorizontalStackLayout>
                            <Label x:Name="savedDistance2" Text="750m"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label x:Name="savedHeart2"
                               Grid.Column="2"
                               Text="❤️"
                               FontSize="20"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRemoveFavoriteTapped" CommandParameter="1"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Frame>

                <!-- Item 3 -->
                <Frame x:Name="savedItem3"
                       BackgroundColor="{StaticResource Surface}"
                       CornerRadius="16"
                       HasShadow="True"
                       Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSavedItemTapped" CommandParameter="2"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="12">
                        <Frame Grid.Column="0"
                               CornerRadius="12"
                               Padding="0"
                               IsClippedToBounds="True"
                               WidthRequest="72"
                               HeightRequest="72"
                               BackgroundColor="#E8F5FF"
                               BorderColor="Transparent">
                            <Label Text="🍲" FontSize="32"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label x:Name="savedName3" Text="Bun Bo Hue"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <HorizontalStackLayout Spacing="2">
                                <Label Text="★★★★" FontSize="12" TextColor="{StaticResource StarFilled}"/>
                                <Label Text="★" FontSize="12" TextColor="{StaticResource StarEmpty}"/>
                                <Label x:Name="savedRating3" Text="4.7" FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" Margin="2,0,0,0"/>
                            </HorizontalStackLayout>
                            <Label x:Name="savedDistance3" Text="1.8km"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label x:Name="savedHeart3"
                               Grid.Column="2"
                               Text="❤️"
                               FontSize="20"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRemoveFavoriteTapped" CommandParameter="2"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Frame>

                <!-- Empty State -->
                <VerticalStackLayout x:Name="emptyStateLayout"
                                     IsVisible="False"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="16"
                                     Margin="0,100">
                    <Label Text="🤍"
                           FontSize="64"
                           HorizontalOptions="Center"/>
                    <Label x:Name="emptyTitleLabel" Text="Bạn chưa lưu quán nào"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalOptions="Center"/>
                    <Label x:Name="emptySubtitleLabel" Text="Khám phá các quán ngon gần bạn"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Button x:Name="exploreButton"
                            Text="Khám phá quán"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="24"
                            Padding="24,12"
                            FontAttributes="Bold"
                            Clicked="OnExploreClicked"
                            HorizontalOptions="Center"
                            Margin="0,8,0,0"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
